# Server-side key for Places API (New)
GOOGLE_PLACES_API_KEY=

# Browser key for Google Maps JS API (restrict by HTTP referrer)
VITE_GOOGLE_MAPS_JS_API_KEY=

# Cache provider: sqlite (local/default) or kv (Vercel KV)
CACHE_PROVIDER=sqlite

# Used when CACHE_PROVIDER=sqlite
SQLITE_CACHE_PATH=.cache/search-cache.sqlite

# 30 days
CACHE_TTL_SECONDS=2592000

# Optional: only required when CACHE_PROVIDER=kv
KV_REST_API_URL=
KV_REST_API_TOKEN=
